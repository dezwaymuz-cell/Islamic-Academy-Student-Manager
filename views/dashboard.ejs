<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Portal | Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="container">
        <header class="dashboard-header">
            <h1>Welcome back! 👋</h1>
            <p>What would you like to do today?</p>
        </header>

        <div class="dashboard-grid">
            <a href="/students" class="dash-card">
                <div class="icon-circle bg-blue">
                    <span class="icon">👥</span>
                </div>
                <h3>View Students</h3>
                <p>Browse the full directory of registered students and manage records.</p>
                <span class="btn-text">Open Directory &rarr;</span>
            </a>

            <a href="/students/new" class="dash-card">
                <div class="icon-circle bg-purple">
                    <span class="icon">➕</span>
                </div>
                <h3>Add Student</h3>
                <p>Register a new admission by filling out the student information form.</p>
                <span class="btn-text">Start Admission &rarr;</span>
            </a>
        </div>

        <footer class="dash-footer">
            <p>&copy; 2026 Student Management System</p>
        </footer>
    </div>

</body>
</html>